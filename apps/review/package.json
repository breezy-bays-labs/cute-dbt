{
  "name": "@cute-dbt/review",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "cute-dbt review app — local-first (zero-egress) Vite + React 19 + Pierre diffs + React Flow + Shiki, rendering the real cute-dbt context payload. Newest-stable, exactly pinned.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check-dist": "bun scripts/check-dist.mjs",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "crap": "crap4ts --config crap4ts.config.ts --coverage coverage/coverage-final.json",
    "mutation": "stryker run",
    "e2e": "playwright test",
    "gate": "bun run build && bun run check-dist && bun run e2e"
  },
  "dependencies": {
    "@pierre/diffs": "1.2.11",
    "@pierre/theming": "0.0.1",
    "@shikijs/core": "4.2.0",
    "@shikijs/langs": "4.2.0",
    "@shikijs/themes": "4.2.0",
    "@xyflow/react": "12.11.1",
    "elkjs": "0.11.1",
    "immer": "10.1.3",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "shiki": "4.2.0",
    "sonner": "2.0.7",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "1.61.1",
    "@stryker-mutator/core": "9.2.0",
    "@stryker-mutator/vitest-runner": "9.2.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "crap4ts": "1.0.1",
    "dependency-cruiser": "17.4.3",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "5.4.0",
    "fast-check": "4.4.0",
    "globals": "^16.0.0",
    "tailwindcss": "4.3.1",
    "ts-morph": "28.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
