  "unit_tests": {
    "unit_test.jaffle_shop.stg_customers.test_stg_customers_renames_columns": {
      "name": "test_stg_customers_renames_columns",
      "model": "stg_customers",
      "given": [
        {
          "input": "ref('raw_customers')",
          "rows": [
            {
              "first_name": "Alice",
              "id": 1,
              "last_name": "A."
            },
            {
              "first_name": "Bob",
              "id": 2,
              "last_name": "B."
            }
          ],
          "format": "dict"
        }
      ],
      "expect": {
        "rows": [
          {
            "customer_id": 1,
            "first_name": "Alice",
            "last_name": "A."
          },
          {
            "customer_id": 2,
            "first_name": "Bob",
            "last_name": "B."
          }
        ],
        "format": "dict"
      },
      "description": "stg_customers renames raw_customers.id/first_name/last_name to\ncustomer_id/first_name/last_name and otherwise passes rows through.\nSynthetic fixture rows — no real customer data.\n",
      "depends_on": {
        "macros": [],
        "nodes": [
          "model.jaffle_shop.stg_customers"
        ]
      }
    }
