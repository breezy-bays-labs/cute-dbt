---
source: tests/golden_report.rs
expression: skeleton
---
<!DOCTYPE html>
<html lang="en" data-style="soft" data-difflayout="auto">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>cute-dbt report</title>
<link rel="icon" href="data:,">
<style></style>
<style></style>
</head>
<body>

<header class="report-header">
  <h1>cute-dbt report</h1>
</header>

<section class="diff-scope-banner" aria-label="Diff scope">
  <p class="diff-scope-line">
    <span class="diff-scope-text">Showing 1 unit test in scope</span> —
    vs baseline manifest <code class="diff-scope-baseline">jaffle-shop-baseline.json</code>.
  </p>

  
  <button type="button" class="pr-comments-count" data-testid="pr-comments-count" hidden></button>
</section>


<div class="settings-cog-wrap">
  <button type="button" class="settings-cog" aria-label="Report settings"
          aria-haspopup="true" aria-expanded="false" aria-controls="settings-panel">
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3.2"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.09A1.65 1.65 0 0 0 9 4.6V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.09a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
  </button>
  <div class="settings-panel" id="settings-panel" role="dialog"
       aria-label="Report settings" hidden>
    <h2>Settings</h2>
    <div class="settings-section appearance-section">
      <h2>Appearance</h2>
      <div class="settings-row settings-row-stack">
        <label>Style</label>
        <div class="style-grid">
          <button type="button" class="style-opt" data-style-id="soft">Soft</button>
          <button type="button" class="style-opt" data-style-id="paper">Paper</button>
          <button type="button" class="style-opt" data-style-id="swiss">Swiss</button>
          <button type="button" class="style-opt" data-style-id="terminal">Terminal</button>
        </div>
      </div>
      <div class="settings-row settings-row-stack">
        <label>Theme</label>
        <div class="theme-grid">
          <button type="button" class="theme-chip" data-theme-id="light"><span class="swatch-dots"><i style="background:#ffffff"></i><i style="background:#1d7484"></i><i style="background:#33363d"></i></span><span class="theme-name">Light</span></button>
          <button type="button" class="theme-chip" data-theme-id="solarized"><span class="swatch-dots"><i style="background:#fdf6e3"></i><i style="background:#268bd2"></i><i style="background:#b58900"></i></span><span class="theme-name">Solarized</span></button>
          <button type="button" class="theme-chip" data-theme-id="latte"><span class="swatch-dots"><i style="background:#eff1f5"></i><i style="background:#1e66f5"></i><i style="background:#8839ef"></i></span><span class="theme-name">Catppuccin Latte</span></button>
          <button type="button" class="theme-chip" data-theme-id="rosepine"><span class="swatch-dots"><i style="background:#faf4ed"></i><i style="background:#286983"></i><i style="background:#907aa9"></i></span><span class="theme-name">Ros&eacute; Pine Dawn</span></button>
          <button type="button" class="theme-chip" data-theme-id="dark"><span class="swatch-dots"><i style="background:#15171c"></i><i style="background:#5fb3c4"></i><i style="background:#d7dae1"></i></span><span class="theme-name">Dark</span></button>
          <button type="button" class="theme-chip" data-theme-id="tokyo"><span class="swatch-dots"><i style="background:#1a1b26"></i><i style="background:#7aa2f7"></i><i style="background:#bb9af7"></i></span><span class="theme-name">Tokyo Night</span></button>
          <button type="button" class="theme-chip" data-theme-id="gruvbox"><span class="swatch-dots"><i style="background:#282828"></i><i style="background:#83a598"></i><i style="background:#fabd2f"></i></span><span class="theme-name">Gruvbox</span></button>
          <button type="button" class="theme-chip" data-theme-id="dracula"><span class="swatch-dots"><i style="background:#282a36"></i><i style="background:#bd93f9"></i><i style="background:#ff79c6"></i></span><span class="theme-name">Dracula</span></button>
        </div>
      </div>
      <div class="settings-row settings-row-stack">
        <label>Accent</label>
        <div class="accent-row">
          <button type="button" class="accent-swatch" data-accent="theme" aria-label="Theme default accent" title="Theme default accent"></button>
          <button type="button" class="accent-swatch" data-accent="teal" style="background:#1d7484" aria-label="teal accent" title="teal accent"></button>
          <button type="button" class="accent-swatch" data-accent="blue" style="background:#2a6fdb" aria-label="blue accent" title="blue accent"></button>
          <button type="button" class="accent-swatch" data-accent="violet" style="background:#7c3aed" aria-label="violet accent" title="violet accent"></button>
          <button type="button" class="accent-swatch" data-accent="green" style="background:#1f8a5b" aria-label="green accent" title="green accent"></button>
          <button type="button" class="accent-swatch" data-accent="amber" style="background:#b45c0c" aria-label="amber accent" title="amber accent"></button>
        </div>
      </div>
      <div class="settings-row settings-row-stack">
        <label>Density</label>
        <div class="seg-radio density-seg">
          <button type="button" data-density="compact">Compact</button>
          <button type="button" data-density="cozy">Cozy</button>
          <button type="button" data-density="comfortable">Roomy</button>
        </div>
      </div>
      <div class="settings-row settings-row-stack">
        <label>Diff layout<span class="settings-hint">side-by-side when there&rsquo;s room</span></label>
        <div class="seg-radio difflayout-seg">
          <button type="button" data-difflayout="auto">Auto</button>
          <button type="button" data-difflayout="unified">Unified</button>
          <button type="button" data-difflayout="split">Split</button>
        </div>
      </div>
      
      <div class="settings-row settings-row-stack">
        <label>DAG engine<span class="settings-hint">Mermaid (static) or Cytoscape (interactive)</span></label>
        <div class="seg-radio engine-seg">
          <button type="button" data-engine="mermaid">Mermaid</button>
          <button type="button" data-engine="cytoscape">Cytoscape</button>
        </div>
      </div>
    </div>
    
    <div class="settings-section experimental-section">
      <div class="settings-row settings-row-stack">
        <label>Experimental
          <span class="settings-hint">unstable surfaces &mdash; defaults may change between versions</span>
        </label>
      </div>
      <div class="settings-row">
        <label for="settings-coverage-input">Coverage intelligence
          <span class="settings-hint">show or hide the coverage-checks surface</span>
        </label>
        <span class="settings-switch">
          <input type="checkbox" id="settings-coverage-input"
                 aria-label="Show coverage-intelligence checks">
          <span class="switch-track" aria-hidden="true"></span>
        </span>
      </div>
    </div>
  </div>
</div><nav class="lens-tabs" role="tablist" aria-label="Report lenses" data-testid="lens-tabs">
  <button type="button" class="lens-tab is-active" role="tab" id="lens-tab-models" aria-selected="true" aria-controls="lens-panel-models" tabindex="0" data-lens="models" data-testid="lens-tab-models">Models</button>
  <button type="button" class="lens-tab" role="tab" id="lens-tab-macros" aria-selected="false" aria-controls="lens-panel-macros" tabindex="-1" data-lens="macros" data-testid="lens-tab-macros">Macros</button>
  <button type="button" class="lens-tab" role="tab" id="lens-tab-project" aria-selected="false" aria-controls="lens-panel-project" tabindex="-1" data-lens="project" data-testid="lens-tab-project">Project</button>
</nav>
<div class="lens-panel is-active" role="tabpanel" id="lens-panel-models" aria-labelledby="lens-tab-models" data-lens="models" data-testid="lens-panel-models"><section class="error-card" role="alert" aria-label="Manifest error">
  <h2>This manifest can't be visualized</h2>
  <div class="error-node-id">node: <code>—</code></div>
  <p class="error-remediation">
    Re-run with <code>dbt compile</code> or <code>dbt run</code> —
    <code>dbt parse</code> does not produce compiled SQL.
  </p>
</section>

<section class="test-selection" aria-label="Test selection">
  
  <div class="axis-filter" role="radiogroup" aria-label="Filter models by change axis" data-testid="axis-filter" hidden></div>
  <p class="removed-models-row" aria-label="Models removed in this PR" data-testid="removed-models" hidden></p>
  <div class="test-selector-row">
    <div class="selector-field">
      <label for="model-select">Model</label>
      <select id="model-select"></select>
      
    </div>
  </div>
  <p class="model-axes-row" data-testid="model-axes" hidden></p>
  
  <p class="model-comments-row" data-testid="model-comments" hidden></p>
  <p class="model-attribution-row" data-testid="model-attribution" hidden></p>
  <p class="zero-updated-hint" data-testid="zero-updated-hint" hidden></p>
</section>


<section class="model-findings" aria-label="Coverage checks" data-testid="model-findings">
  <div class="findings-header">
    <h2>Coverage checks</h2>
    <p class="findings-subtitle">Static checks over the manifest and compiled SQL — tiers are labeled, never averaged.</p>
  </div>
  <div class="findings-body"></div>
</section>

<section class="model-sql" aria-label="Model SQL">
  <details class="model-sql-details">
    <summary>Model SQL<span class="model-sql-summary-hint">raw, with Jinja</span></summary>
    
    <div class="sql-block-wrap model-sql-wrap">
      <pre class="sql-block model-sql-block"><code class="model-sql-code"></code></pre>
    </div>
  </details>
</section>


<section class="model-yaml" aria-label="Model YAML">
  <details class="model-yaml-details">
    <summary>Model YAML<span class="model-yaml-summary-hint">authored schema entry</span></summary>
    <div class="sql-block-wrap model-yaml-wrap">
      <pre class="sql-block model-yaml-block"><code class="model-yaml-code"></code></pre>
    </div>
  </details>
</section>

<section class="cte-dag" aria-label="CTE dependency DAG">
  <div class="cte-dag-header">
    <h2>CTE dependency DAG</h2>
    
    <button type="button" class="expect-tooltip cte-dag-hint" aria-label="Click a node (or Tab to it and press Enter) to inspect.">ⓘ<span class="expect-tooltip-bubble" aria-hidden="true">Click a node (or Tab to it and press Enter) to inspect.</span></button>
  </div>
  <div class="recursive-banner" hidden>
    Recursive CTE present; recursive arm omitted from DAG (v0.1 limit).
  </div>
  
  <div class="dag-stage">
    <div class="dag-canvas-col">
      <div class="cte-dag-mermaid"></div>
      
      <div class="cte-dag-cyto is-hidden">
        <div class="cyto-canvas" aria-label="Interactive CTE DAG (Cytoscape)"></div>
        <div class="cyto-node-card" role="status" aria-live="polite"></div>
      </div>
      <div class="dag-legend">
        <div class="dag-legend-group">
          <span class="dag-legend-title">node role</span>
          <span class="dag-legend-roles"></span>
        </div>
        <div class="dag-legend-group">
          <span class="dag-legend-title">edge type</span>
          <span class="dag-legend-joins"></span>
        </div>
      </div>
    </div>
    <aside class="dag-shelf" aria-label="Node detail" hidden>
      <div class="dag-shelf-head">
        <span class="dag-shelf-title">Node detail</span>
        <button type="button" class="dag-shelf-close" aria-label="Close node detail">✕</button>
      </div>
      <div class="dag-shelf-body"></div>
    </aside>
  </div>
</section>


<section class="test-section" aria-label="Unit test">
  <div class="test-card">
    <div class="test-card-head">
      <div class="selector-field test-select-field">
        <label for="test-select">Unit test</label>
        <select id="test-select"></select>
      </div>
      <div class="test-mode-toggle" role="group" aria-label="Test scope" data-testid="updated-toggle">
        <button type="button" data-test-mode="updated" class="is-active" aria-pressed="true">Updated only</button>
        <button type="button" data-test-mode="all" aria-pressed="false">All tests</button>
      </div>
      <div class="test-badges"></div>
    </div>
    <p class="test-description" hidden></p>
    <div class="test-details-body"></div>
  </div>
</section>

<div class="panel-row">

  <section class="panel left-panel" aria-label="Given inputs">
    
    <div class="panel-header">
      <h2>Given</h2>
    </div>
    <div class="left-panel-body" data-mode="inputs"></div>
  </section>

  <section class="panel expected-panel" aria-label="Expected output">
    <div class="panel-header">
      <h2>Expected</h2>
      <span class="row-count-badge expected-rowcount">0 rows</span>
    </div>
    <div class="expected-body"></div>
  </section>

</div></div>
<div class="lens-panel" role="tabpanel" id="lens-panel-macros" aria-labelledby="lens-tab-macros" data-lens="macros" data-testid="lens-panel-macros" hidden></div>
<div class="lens-panel" role="tabpanel" id="lens-panel-project" aria-labelledby="lens-tab-project" data-lens="project" data-testid="lens-panel-project" hidden>
</div>

<script type="application/json" id="cute-dbt-data"></script>

<script></script>
<script></script>
<script></script>
<script></script>

<script></script>
<script></script>
<script></script>
<script></script>
</body>
</html>
