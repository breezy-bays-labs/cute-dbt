diff --git a/models/marts/analytics/fct_provider_scorecard.sql b/models/marts/analytics/fct_provider_scorecard.sql
new file mode 100644
--- /dev/null
+++ b/models/marts/analytics/fct_provider_scorecard.sql
@@ -0,0 +1,14 @@
+{{
+    config(
+        materialized='table',
+        tags=['analytics', 'scorecard']
+    )
+}}
+
+-- A new provider scorecard model added in this PR (cute-dbt#416 NEW state).
+select
+    provider_id
+    , avg(quality_score) as avg_quality_score
+    , count(*) as encounter_count
+from {{ ref('fct_provider_metrics') }}
+group by provider_id
